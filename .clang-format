# 基础风格：Google风格
# 可选：LLVM, Google, Chromium, Mozilla, WebKit, Microsoft
BasedOnStyle: Google

# 语言标准：C++17
Language: Cpp
Standard: c++17

# 缩进与对齐:
IndentWidth: 4                          # 4空格缩进（和.editorconfig保持一致）
TabWidth: 4                             # Tab宽度4空格
UseTab: Never                           # 永远不用Tab，只用空格
ColumnLimit: 120                        # 最大行宽120字符（和.editorconfig保持一致）

# 指针/引用对齐：
# 类型左边（int* p; 而不是 int *p; 或 int * p;）
# 可选：Left, Right, Middle
PointerAlignment: Left
ReferenceAlignment: Left

# 初始化列表对齐：
# 冒号对齐
AlignAfterOpenBracket: Align
AlignConsecutiveAssignments: false     # 不对齐连续赋值（避免无意义的diff）
AlignConsecutiveDeclarations: false    # 不对齐连续声明
AlignOperands: Align                    # 对齐操作数
AlignTrailingComments: true             # 对齐行尾注释

# 括号与换行：
# 可读性优先
# 可选：Attach, Linux, Mozilla, Stroustrup, Allman, Whitesmiths
BreakBeforeBraces: Attach                # 大括号不换行（Google风格：if (...) {）

AllowShortBlocksOnASingleLine: Empty    # 只有空块允许写在一行
AllowShortFunctionsOnASingleLine: Empty # 只有空函数允许写在一行
AllowShortIfStatementsOnASingleLine: Never # 永远不把if写在一行
AllowShortLoopsOnASingleLine: false     # 永远不把循环写在一行

# 命名空间缩进：不缩进命名空间里的内容
NamespaceIndentation: None

# 头文件包含：
# 自动排序
SortIncludes: true                       # 自动排序头文件
IncludeBlocks: Regroup                   # 自动分组头文件
IncludeCategories:                      # 头文件分组规则（按优先级排序）
  - Regex: '^".*"'                      # 1. 自己项目的头文件（"xxx.h"）
    Priority: 1
  - Regex: '^<.*\.h>'                   # 2. C标准库头文件（<stdio.h>）
    Priority: 2
  - Regex: '^<[^.]*>'                   # 3. C++标准库头文件（<vector>）
    Priority: 3
  - Regex: '^<.*>'                      # 4. 第三方库头文件（<opencv2/opencv.hpp>）
    Priority: 4
IncludeIsMainRegex: '([-_](test|unittest))?$'

# 其他细节：C++17适配
Cpp11BracedListStyle: true              # C++11初始化列表风格
FixNamespaceComments: true               # 自动修复命名空间注释
SpaceBeforeCpp11BracedList: false       # C++11初始化列表前不加空格
SpaceBeforeInheritanceColon: false       # 继承冒号前不加空格
SpaceBeforeCtorInitializerColon: false   # 构造函数初始化列表冒号前不加空格
